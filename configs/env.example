# --- QTrader v4 Environment Configuration ---

# 1. Exchange API Keys (Binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# 2. Exchange API Keys (Coinbase Advanced Trade)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
COINBASE_KEY_NAME=organizations/ORG_ID/apiKeys/KEY_ID
COINBASE_PRIVATE_KEY=
COINBASE_REST_BASE=https://api.coinbase.com

# 3. Universal Data Lake (S3 / GCS / Local)
# For S3: s3://bucket-name, For GCS: gs://bucket-name, For Local: /path/to/data
DATALAKE_URI=./data_lake
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your_s3_key
S3_SECRET_KEY=your_s3_secret
GCS_PROJECT_ID=your_gcs_project

# 4. Machine Learning & Tracking (MLflow)
MLFLOW_TRACKING_URI=http://localhost:5050
MLFLOW_EXPERIMENT_NAME=qtrader_v4_autonomous

# 5. Distributed Compute (Ray)
RAY_ADDRESS=auto
RAY_NAMESPACE=qtrader
RAY_MEMORY=4G
RAY_CPUS=2

# 6. Operational Guardrails
MONTHLY_CLOUD_BUDGET=1000.0
MAX_LATENCY_TOLERANCE_MS=100

# 6b. Execution Impact Defaults
IMPACT_DAILY_VOLUME=1000000
IMPACT_SIGMA_DAILY=0.02
IMPACT_Y=1.0

# 7. Persistent Storage (PostgreSQL)
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_TYPE=postgres
DATABASE_HOST=timescaledb
DATABASE_PORT=5432
DATABASE_USERNAME=sanauto
DATABASE_PASSWORD=secret
DATABASE_NAME=qtrader
DATABASE_SYNCHRONIZE=true
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_URL=postgresql://sanauto:secret@timescaledb:5432/qtrader

# 8. Trading Mode (True = Paper Trading, False = Live)
SIMULATE_MODE=True
LOG_LEVEL=INFO
