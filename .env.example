# --- QTrader v4 Institutional Environment Configuration ---
# All sensitive values must be replaced with actual credentials in your local .env file.
# DO NOT COMMIT THE .env FILE TO VERSION CONTROL.

# ============================================================
# 1. EXCHANGE API KEYS (Live Trading)
# ============================================================
# Binance API (Required for live_trader.py if using Binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Coinbase Advanced Trade (Required for live_trader.py if using Coinbase)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
COINBASE_KEY_NAME=organizations/your_org_id/apiKeys/your_key_id
COINBASE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
COINBASE_REST_BASE=https://api.coinbase.com/api/v3

# ============================================================
# 2. AI HYBRID TRIO (V4 Modernized Orchestrator)
# ============================================================
# Ollama Backend URL (qt-ollama container or local)
OLLAMA_URL=http://ollama:11434

# Stage 1: Forecast (Trend Projection)
# Optimized: llama3.2:1b (latency < 30ms) or chronos (transformer)
TS_FORECAST_MODEL=llama3.2:1b

# Stage 2: Risk (Classification & Guardrails)
# Optimized: qwen3.5:2b or XGBoost (tabular)
TS_RISK_MODEL=qwen3.5:2b

# Stage 3: Decision (Orchestration & RAG)
# Optimized: gemma4:e2b (Reasoning) or llama3.2:3b
TS_DECISION_MODEL=gemma4:e2b

# Hugging Face Token (Required for local model downloads/CHRONOS)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ============================================================
# 3. CORE INFRASTRUCTURE (Storage & Cache)
# ============================================================
# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://sanauto:secret@timescaledb:5432/qtrader
DATABASE_HOST=timescaledb
DATABASE_PORT=5432
DATABASE_USERNAME=sanauto
DATABASE_PASSWORD=secret
DATABASE_NAME=qtrader

# Redis (State store & Message broker - Mandatory for V4)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=qtrader

# MLflow (Experiment tracking)
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=qtrader_v4_autonomous

# ============================================================
# 4. TRADING STRATEGY & GUARDRAILS
# ============================================================
# Symbol selection (comma-separated)
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# Operational Constraints
SIMULATE_MODE=True  # Set to False for Live Trading
LOG_LEVEL=INFO
TIMEZONE=Asia/Ho_Chi_Minh
MONTHLY_CLOUD_BUDGET=1000.0

# Latency and Risk limits
TS_MAX_LATENCY_MS=150
TS_MAX_POSITION_USD=100000.0
TS_MAX_DRAWDOWN_PCT=0.20

# ============================================================
# 5. ALERTING & SECURITY
# ============================================================
# JWT Security (API Dashboard)
JWT_SECRET_KEY=your_secure_jwt_secret_here

# Telegram Alerts
TELEGRAM_ALERTS_ENABLED=False
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email Alerts (SMTP)
ALERT_EMAIL_ENABLED=False
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SENDER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
