{
  "guards": [
    {
      "module": "qtrader.core.orchestrator",
      "target": "handle_market_data",
      "constraint": ["C3", "C4", "C6"],
      "action": "BLOCK"
    },
    {
      "module": "qtrader.core.orchestrator",
      "target": "handle_signals",
      "constraint": ["C3", "C4"],
      "action": "HALT_SYSTEM"
    },
    {
      "module": "qtrader.portfolio.allocator",
      "target": "allocate",
      "constraint": ["C4", "C5"],
      "action": "WARN"
    },
    {
      "module": "qtrader.execution.adapters.binance",
      "target": "submit_order",
      "constraint": ["C3", "C4", "C6"],
      "action": "HALT_SYSTEM"
    }
  ]
}
